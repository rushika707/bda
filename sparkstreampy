from pyspark.sql import SparkSession
from pyspark.sql.functions import sum
from pyspark.sql.types import StructType, StructField, IntegerType, DoubleType

# Initialize Spark
spark = SparkSession.builder \
    .appName("RetailStoreStreaming") \
    .getOrCreate()

spark.sparkContext.setLogLevel("ERROR")

# Schema
schema = StructType([
    StructField("ProductID", IntegerType(), True),
    StructField("Amount", DoubleType(), True)
])

# Input path
input_path = "/home/vboxuser/spark_input"

# Read stream
retail_stream_df = spark.readStream \
    .format("csv") \
    .option("header", "true") \
    .schema(schema) \
    .load(input_path)

# Process
processed_df = retail_stream_df.groupBy("ProductID") \
    .agg(sum("Amount").alias("TotalSales"))

# Output
query = processed_df.writeStream \
    .outputMode("complete") \
    .format("console") \
    .start()

query.awaitTermination()
spark-submit sparkstream.py
