import RPi.GPIO as GPIO
import time

# GPIO setup
GPIO.setmode(GPIO.BOARD)
GPIO.setwarnings(False)

RAIN_PIN = 37   # Change based on your wiring

GPIO.setup(RAIN_PIN, GPIO.IN)

print("Rain Detection Started...")

try:
    while True:
        rain = GPIO.input(RAIN_PIN)

        if rain == 0:   # Rain detected
            print("🌧️ Rain Detected")
        else:
            print("☀️ No Rain")

        time.sleep(2)

except KeyboardInterrupt:
    print("Program Stopped")
    GPIO.cleanup()
